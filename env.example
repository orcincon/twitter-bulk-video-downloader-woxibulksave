# WoxiBulkSave — copy to .env.local and set in Vercel Environment Variables
# Uyum: NEXTAUTH_URL ile NEXT_PUBLIC_SITE_URL aynı siteyi göstermeli (production'da).

# --- Site URL (SEO, layout, sitemap) ---
# Production: https://www.woxibulksave.com  (trailing slash YOK)
# Local:      http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://www.woxibulksave.com

# --- NextAuth URL (OAuth callback ve redirect için — kod: lib/auth.js) ---
# Production: site ile birebir aynı olmalı (NEXTAUTH_URL = NEXT_PUBLIC_SITE_URL)
# Local:      http://localhost:3000
# Not: Yanlış veya eksik olursa Twitter giriş sonrası redirect bozulur.
NEXTAUTH_URL=https://www.woxibulksave.com

# --- NextAuth secret (JWT/session imzalama — kod: lib/auth.js) ---
# Zorunlu: Production'da mutlaka güçlü rastgele bir değer verin (örn. openssl rand -base64 32).
# Boş bırakırsanız kod fallback kullanır; secret değişince tüm oturumlar geçersiz olur.
NEXTAUTH_SECRET=

# OAuth access/refresh token şifreleme (lib/token-crypto.js). Boşsa NEXTAUTH_SECRET kullanılır.
# Production'da ayrı anahtar önerilir: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Google Search Console & Bing Webmaster (meta tag doğrulama)
# GOOGLE_SITE_VERIFICATION=abc123...
# BING_SITE_VERIFICATION=xyz789...

# --- Twitter OAuth (Twitter Developer Portal) ---
NEXT_PUBLIC_TWITTER_CLIENT_ID=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Kamikaze yönetim paneli (/kamikaze) - izin verilen tek kullanıcı (şifreyi sadece .env.local'da kullanın)
KAMIKAZE_EMAIL=form78@gmail.com
KAMIKAZE_SECRET=

# --- Supabase (lib/supabase.js ile isimler birebir aynı olmalı) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Tablo: analysis_logs (Supabase paneldeki isimle aynı)
# Migration: Supabase Dashboard > SQL Editor > 010_disable_rls_analysis_logs.sql

# ========== .env.local uyum kontrolü ==========
# 1) NEXTAUTH_URL = tam site adresi, sonda / OLMAMALI
# 2) NEXT_PUBLIC_SITE_URL = NEXTAUTH_URL ile aynı (production)
# 3) NEXTAUTH_SECRET = production'da dolu
# 4) Supabase yazma için: NEXT_PUBLIC_SUPABASE_URL + (SUPABASE_SERVICE_ROLE_KEY veya NEXT_PUBLIC_SUPABASE_ANON_KEY) — isimler env.example ile aynen
